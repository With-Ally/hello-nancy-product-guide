{
  "functions": {
    "api/search.py": { "maxDuration": 60 },
    "api/score.py": { "maxDuration": 30 },
    "api/suggested.py": { "maxDuration": 30 },
    "api/products.py": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/products", "destination": "/api/products" },
    { "source": "/suggested", "destination": "/api/suggested" },
    { "source": "/score", "destination": "/api/score" },
    { "source": "/search", "destination": "/api/search" },
    { "source": "/style.css", "destination": "/web/style.css" },
    { "source": "/((?!api/).*)", "destination": "/web/index.html" }
  ]
}
